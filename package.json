    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.27.2",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
